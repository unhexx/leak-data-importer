# Пример окружения для docker-compose и локального запуска
# Скопируйте в .env и отредактируйте под себя

# PostgreSQL (для db слоя)
DATABASE_URL=postgresql://leak:leak@localhost:5432/leak_data

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me

# Опционально: путь к данным по умолчанию для импорта
LEAK_DATA_INPUT_DIR=./data/input

# Логи и безопасность
LOG_LEVEL=INFO
# REDACTION_LEVEL=standard   # standard | none
